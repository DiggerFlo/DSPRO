# ─── NZZ ContextAI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# ─── Data Paths ───────────────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CHUNKS_DATA_DIR=data/chunks
EMBEDDINGS_DATA_DIR=data/embeddings

# ─── Embedding Model ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768

# ─── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=data/embeddings/chroma_db
VECTOR_STORE_COLLECTION=nzz_articles

# ─── LLM (optional — API-based) ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4o-mini

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=experiments/mlflow
MLFLOW_EXPERIMENT_NAME=nzz-contextai

# ─── Retrieval Settings ───────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ─── Chunking Settings ────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
