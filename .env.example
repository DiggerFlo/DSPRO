# ─── NZZ ContextAI — Environment Variables ────────────────────────────────────
# Diese Datei als .env kopieren und Werte eintragen.
# Die .env Datei niemals ins Git committen!

# ─── HuggingFace ──────────────────────────────────────────────────────────────
# Token unter: huggingface.co → Settings → Access Tokens (Read reicht)
HF_TOKEN=hf_your_token_here

# ─── LLM (optional — für API-basierte Generierung) ────────────────────────────
OPENAI_API_KEY=your_openai_key_here
